{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_FRONTEND_API": false,
        "ENABLE_QT": false
      }
    },
    {
      "name": "windows-x64",
      "displayName": "Windows x64 (VS 2022)",
      "description": "Build for Windows x64 with Visual Studio 17 2022",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64,version=10.0.22621",
      "warnings": {"dev": true, "deprecated": true}
    },
    {
      "name": "windows-x64-vs18",
      "displayName": "Windows x64 (VS 2026 / VS 18)",
      "description": "Build for Windows x64 with Visual Studio 18 2026 + vcpkg toolchain",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "warnings": {"dev": true, "deprecated": true},
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "macos",
      "displayName": "macOS Universal",
      "description": "Build for macOS 11.0+ (Universal binary) with Xcode",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_macos",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "generator": "Xcode",
      "warnings": {"dev": true, "deprecated": true},
      "cacheVariables": {
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CODESIGN_IDENTITY": "$penv{CODESIGN_IDENTITY}",
        "CODESIGN_TEAM": "$penv{CODESIGN_TEAM}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64",
      "configurePreset": "windows-x64",
      "displayName": "Windows x64 (VS 2022)",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-x64-vs18",
      "configurePreset": "windows-x64-vs18",
      "displayName": "Windows x64 (VS 2026)",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "macos",
      "configurePreset": "macos",
      "displayName": "macOS Universal",
      "configuration": "RelWithDebInfo"
    }
  ]
}
